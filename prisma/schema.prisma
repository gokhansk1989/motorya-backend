// ============================================================
//  MOTORYA — Motosiklet Ekipman Pazarı · Veri Modeli
//  Prisma + PostgreSQL · mobil-hazır (web + Android + iOS)
// ------------------------------------------------------------
//  Tasarım ilkeleri:
//   - Kimlikler CUID (tahmin edilemez, mobil senkron dostu)
//   - Her kritik tabloda updatedAt + soft delete (deletedAt)
//   - Para alanları Decimal(12,2), kuruş hatası yok
//   - Platform araya girmez: ilan ver, mesajlaş, anlaş (Letgo modeli)
//   - Çift yönlü yorum (alıcı<->satıcı), ilan bazlı
//   - RESERVED durumu 48 saat otomatik açılır
//   - Ücretsiz->ücretli geçiş PlatformSetting + Plan ile feature-flag'li
//   - Cihaz/oturum ve push token mobil için baştan modelde
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
//  1) KİMLİK & DOĞRULAMA
// ============================================================

enum UserRole {
  USER
  MODERATOR
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  PENDING // e-posta/telefon doğrulaması bekliyor
  ACTIVE
  SUSPENDED // geçici askı
  BANNED
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  phone        String?    @unique
  tcKimlik     String?    @unique
  passwordHash String?
  googleId     String?    @unique
  displayName  String
  avatarUrl    String?
  bio          String?
  city         String?
  role         UserRole   @default(USER)
  status       UserStatus @default(PENDING)

  // Doğrulama zaman damgaları — hızlı sorgu için User üstünde tutulur.
  // Detaylı KYC inceleme akışı ise VerificationRequest tablosunda.
  phoneVerifiedAt    DateTime?
  emailVerifiedAt    DateTime?
  identityVerifiedAt DateTime?
  ibanVerifiedAt     DateTime?

  // Banka/IBAN (satıcıya aktarım için; gerçek IBAN şifreli saklanır)
  payoutIban String?
  payoutName String?

  // Denormalize itibar alanları (sipariş/yorum sonrası job ile güncellenir)
  ratingAvg   Float   @default(0)
  ratingCount Int     @default(0)
  salesCount  Int     @default(0)
  isFounder   Boolean @default(false) // "Kurucu Üye" rozeti

  emailVerificationToken  String?   @unique
  emailVerificationExpiry DateTime?
  passwordResetToken      String?   @unique
  passwordResetExpiry     DateTime?

  adminMfaOtp       String?
  adminMfaOtpExpiry DateTime?

  vacationMode  Boolean   @default(false)
  vacationSince DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // İlişkiler
  listings                 Listing[]
  favorites                Favorite[]
  offers                   Offer[]
  reviewsWritten           Review[]                  @relation("ReviewAuthor")
  reviewsReceived          Review[]                  @relation("ReviewTarget")
  devices                  Device[]
  pushTokens               PushToken[]
  verifications            VerificationRequest[]
  subscription             Subscription?
  notifications            Notification[]
  webPushSubscriptions     WebPushSubscription[]
  savedSearches            SavedSearch[]
  reportsMade              Report[]                  @relation("Reporter")
  auditLogs                AuditLog[]                @relation("AuditActor")
  conversationParticipants ConversationParticipant[]
  sentMessages             Message[]                 @relation("SentMessages")
  following                UserFollow[]              @relation("Follower")
  followers                UserFollow[]              @relation("Following")
  blockedUsers             UserBlock[]               @relation("Blocker")
  blockedBy                UserBlock[]               @relation("Blocked")

  @@index([status, createdAt])
  @@index([city])
}

enum Platform {
  WEB
  IOS
  ANDROID
}

/// Her giriş yapılan cihaz/oturum. Mobil "bu cihazdan çıkış yap" için ayrı kayıt.
model Device {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform         Platform
  model            String? // "iPhone 15", "Pixel 8" vb.
  refreshTokenHash String // refresh token'ın hash'i; iptal/rotasyon için
  appVersion       String? // zorunlu güncelleme kontrolü için
  lastSeenAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())
  revokedAt        DateTime?

  pushTokens PushToken[]

  @@index([userId])
}

/// FCM (Android) / APNs (iOS) push bildirim anahtarları.
model PushToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId   String?
  device     Device?   @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  platform   Platform
  token      String    @unique
  createdAt  DateTime  @default(now())
  disabledAt DateTime?

  @@index([userId])
}

enum VerificationType {
  PHONE
  EMAIL
  IDENTITY // TC kimlik / KYC
  IBAN
}

enum VerificationState {
  PENDING
  APPROVED
  REJECTED
}

/// KYC inceleme kuyruğu (admin moderasyonu). Onaylanınca User üstündeki
/// *VerifiedAt alanı set edilir.
model VerificationRequest {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        VerificationType
  state       VerificationState @default(PENDING)
  // Sağlayıcı referansı / belge bağlantısı (şifreli depolanır)
  providerRef String?
  documentUrl String?
  reviewNote  String?
  reviewedBy  String?
  createdAt   DateTime          @default(now())
  reviewedAt  DateTime?

  @@index([state, createdAt])
  @@index([userId])
}

// ============================================================
//  2) KATALOG (KATEGORİ / MARKA / İLAN)
// ============================================================

/// Hiyerarşik kategori: Kask > Tam Yüz, Mont > Deri vb.
model Category {
  id        String     @id @default(cuid())
  name      String
  slug      String     @unique
  parentId  String?
  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  iconKey   String? // arayüzdeki ikon eşlemesi
  sortOrder Int        @default(0)
  isActive  Boolean    @default(true)
  listings  Listing[]

  @@index([parentId])
}

model Brand {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  logoUrl  String?
  listings Listing[]
}

enum ListingGender {
  ERKEK
  KADIN
  UNISEX
  COCUK
}

enum ListingCondition {
  NEW // Sıfır / Etiketli
  LIKE_NEW // Çok iyi
  GOOD // İyi
  FAIR // İdare eder
}

enum ListingStatus {
  DRAFT
  PENDING_REVIEW // moderasyon kuyruğunda
  ACTIVE
  RESERVED // teklif/sipariş ile rezerve
  SOLD
  REJECTED
  ARCHIVED
}

model Listing {
  id         String   @id @default(cuid())
  sellerId   String
  seller     User     @relation(fields: [sellerId], references: [id])
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  brandId    String?
  brand      Brand?   @relation(fields: [brandId], references: [id])

  title         String
  description   String
  condition     ListingCondition
  gender        ListingGender? // Giyim kategorileri için
  sizeLabel     String? // "M (57-58)", "52", "43" vb.
  price         Decimal          @db.Decimal(12, 2)
  originalPrice Decimal?         @db.Decimal(12, 2) // üstü çizili fiyat
  currency      String           @default("TRY")
  city          String?
  status        ListingStatus    @default(PENDING_REVIEW)

  // Para kazandıran alanlar (vitrin / öne çıkarma)
  isFeatured    Boolean   @default(false)
  featuredUntil DateTime?

  // Rezervasyon — teklif/mesaj üzerine satıcı rezerve edebilir, 48 saat sonra otomatik açılır
  reservedUntil DateTime?

  // Denormalize sayaçlar
  viewCount     Int @default(0)
  favoriteCount Int @default(0)

  tags        String[]  @default([])

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  images        ListingImage[]
  favorites     Favorite[]
  offers        Offer[]
  reviews       Review[]
  reports       Report[]
  conversations Conversation[]

  // Cursor tabanlı sayfalama ve filtreleme için indeksler
  @@index([status, createdAt])
  @@index([categoryId, status])
  @@index([sellerId])
  @@index([isFeatured, featuredUntil])
}

model ListingImage {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int     @default(0)
  width     Int?
  height    Int?

  @@index([listingId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model UserBlock {
  id        String   @id @default(cuid())
  blockerId String
  blocker   User     @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blockedId String
  blocked   User     @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

enum OfferStatus {
  PENDING
  COUNTER_OFFERED
  ACCEPTED
  REJECTED
  EXPIRED
  WITHDRAWN
}

/// "Teklif ver" akışı: alıcı pazarlık fiyatı önerir.
model Offer {
  id              String      @id @default(cuid())
  listingId       String
  listing         Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId         String
  buyer           User        @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  amount          Decimal     @db.Decimal(12, 2)
  message         String?
  status          OfferStatus @default(PENDING)
  counterAmount   Decimal?    @db.Decimal(12, 2)
  counterMessage  String?
  expiresAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([listingId, status])
  @@index([buyerId])
}

// ============================================================
//  3) ÇİFT YÖNLÜ YORUM & İTİBAR
// ============================================================

enum ReviewDirection {
  BUYER_TO_SELLER
  SELLER_TO_BUYER
}

/// Yorum daima tamamlanmış bir siparişe bağlıdır (sahte yorum engeli).
/// Her sipariş için her yönde en fazla 1 yorum.
/// Yorum — ilan bazlı, her ilan için her yönde en fazla 1 yorum.
model Review {
  id           String          @id @default(cuid())
  listingId    String
  listing      Listing         @relation(fields: [listingId], references: [id], onDelete: Cascade)
  authorId     String
  author       User            @relation("ReviewAuthor", fields: [authorId], references: [id])
  targetUserId String
  targetUser   User            @relation("ReviewTarget", fields: [targetUserId], references: [id])
  direction    ReviewDirection
  rating       Int // 1..5
  comment      String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@unique([listingId, direction])
  @@index([targetUserId, createdAt])
}

// ============================================================
//  4) ÜYELİK PLANLARI & GELİR (ücretsiz -> ücretli)
// ============================================================

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}

/// Plan tanımı (Sürücü / Sürücü+ / Mağaza). commissionRate ve limitler
/// burada tutulur; lansmanda komisyon 0, sonra güncellenir.
model Plan {
  id                String  @id @default(cuid())
  name              String  @unique
  slug              String  @unique
  priceMonthly      Decimal @default(0) @db.Decimal(10, 2)
  commissionRate    Decimal @default(0) @db.Decimal(5, 4) // 0.0800 = %8
  maxActiveListings Int? // null = sınırsız
  featuredCredits   Int     @default(0) // aylık öne çıkarma hakkı
  features          Json? // serbest özellik bayrakları
  isActive          Boolean @default(true)
  sortOrder         Int     @default(0)

  subscriptions Subscription[]
}

model Subscription {
  id               String             @id @default(cuid())
  userId           String             @unique
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId           String
  plan             Plan               @relation(fields: [planId], references: [id])
  status           SubscriptionStatus @default(ACTIVE)
  founderDiscount  Boolean            @default(false) // kurucu üye indirimi
  currentPeriodEnd DateTime?
  cancelAt         DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([status])
}

// ============================================================
//  5) MESAJLAŞMA
// ------------------------------------------------------------
//  Her konuşma (Conversation) iki kullanıcı arasında, isteğe
//  bağlı bir ilan bağlamında açılır. Mesajlar AES-256-GCM ile
//  şifreli saklanır; anahtar her konuşmaya özel üretilip
//  master key ile sarmalanır (key escrow). SUPER_ADMIN dispute
//  durumunda admin endpoint üzerinden açabilir; her erişim
//  AuditLog'a düşer.
// ============================================================

model Conversation {
  id           String   @id @default(cuid())
  listingId    String?
  listing      Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  // Şifreli konuşma anahtarı (AES-256 key, master key ile wrap edilmiş)
  encryptedKey String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]

  @@index([listingId])
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Son okunma zamanı — okunmamış sayısı buradan hesaplanır
  lastReadAt     DateTime?
  createdAt      DateTime     @default(now())

  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  // Şifreli içerik: IV + şifreli metin, base64 formatında
  encryptedBody  String
  // Silindi mi? (soft delete — şifreli içerik silinir, kayıt kalır)
  deletedAt      DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@index([senderId])
}

// ============================================================
//  6) MODERASYON, BİLDİRİM, AYAR & DENETİM
// ============================================================

enum ReportTargetType {
  LISTING
  USER
}

enum ReportStatus {
  OPEN
  REVIEWED
  ACTIONED
  DISMISSED
}

/// İlan/üye şikayeti (sahte ürün, kural ihlali vb.).
model Report {
  id           String           @id @default(cuid())
  reporterId   String
  reporter     User             @relation("Reporter", fields: [reporterId], references: [id])
  targetType   ReportTargetType
  listingId    String?
  listing      Listing?         @relation(fields: [listingId], references: [id])
  targetUserId String?
  reason       String
  status       ReportStatus     @default(OPEN)
  createdAt    DateTime         @default(now())
  reviewedAt   DateTime?

  @@index([status, createdAt])
}

/// Kullanıcının kaydettiği arama kriterleri — yeni ilan eşleştiğinde bildirim tetikler.
model SavedSearch {
  id             String            @id @default(cuid())
  userId         String
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  label          String
  search         String?
  categoryId     String?
  brandId        String?
  city           String?
  condition      ListingCondition?
  minPrice       Decimal?          @db.Decimal(12, 2)
  maxPrice       Decimal?          @db.Decimal(12, 2)
  lastNotifiedAt DateTime?
  createdAt      DateTime          @default(now())

  @@index([userId])
}

/// Çok kanallı bildirim (push + uygulama içi). type serbest string + payload.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String // "order.shipped", "offer.received" vb.
  title     String
  body      String?
  payload   Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

model WebPushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

/// Global platform ayarları (feature-flag). Ücretsiz->ücretli geçiş anahtarı
/// burada yaşar: örn. { "monetizationEnabled": false, "launchMode": true }.
model PlatformSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

/// Blog yazıları — admin panelden yönetilir, frontend'de statik veri yerine buradan çekilir.
model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String
  content     String    @db.Text
  category    String
  tags        String[]  @default([])
  coverEmoji  String    @default("📝")
  coverImage  String?
  author      String    @default("Motorya Editörü")
  readTime    Int       @default(5)
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([published, publishedAt])
}

/// Servis entegrasyonları (SendGrid, PayTR vb.) — config JSON şifreli değil, hassas alanlar maskelenir
model Integration {
  id        String   @id @default(cuid())
  key       String   @unique // 'sendgrid', 'paytr', 'netgsm' vb.
  name      String
  enabled   Boolean  @default(false)
  config    Json     @default("{}")
  updatedAt DateTime @updatedAt

  @@index([key])
}

/// Statik içerik sayfaları (Hakkımızda, Gizlilik, vb.)
model StaticPage {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String   @db.Text
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

/// Admin işlem günlüğü (kim, neyi, ne zaman değiştirdi).
model AuditLog {
  id        String   @id @default(cuid())
  actorId   String
  actor     User     @relation("AuditActor", fields: [actorId], references: [id])
  action    String // "listing.approve", "user.suspend" vb.
  entity    String
  entityId  String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([actorId, createdAt])
}

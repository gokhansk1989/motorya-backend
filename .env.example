# ============ DATABASE ============
DB_NAME=vites
DB_USER=postgres
DB_PASSWORD=dev-password
DATABASE_URL=postgresql://postgres:dev-password@localhost:5432/vites

# ============ REDIS ============
REDIS_URL=redis://localhost:6379

# ============ AUTH ============
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRATION=24h

# ============ ENVIRONMENT ============
NODE_ENV=development
PORT=3000

# ============ CORS ============
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ============ PAYMENT PROVIDERS (ilerde) ============
# IYZICO_API_KEY=...
# IYZICO_SECRET_KEY=...
# PAYTR_MERCHANT_ID=...
# PAYTR_API_KEY=...

# ============ SMS/EMAIL (ilerde) ============
# NETGSM_USERNAME=...
# NETGSM_PASSWORD=...
# SENDGRID_API_KEY=...

# ============ STORAGE (ilerde) ============
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_BUCKET=...

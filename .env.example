# ============ DATABASE ============
DB_NAME=vites
DB_USER=postgres
DB_PASSWORD=dev-password
DATABASE_URL=postgresql://postgres:dev-password@localhost:5432/vites

# ============ REDIS ============
REDIS_URL=redis://localhost:6379

# ============ AUTH ============
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRATION=24h

# ============ ENVIRONMENT ============
NODE_ENV=development
PORT=3000

# ============ CORS ============
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ============ PAYMENT PROVIDERS (ilerde) ============
# IYZICO_API_KEY=...
# IYZICO_SECRET_KEY=...
# PAYTR_MERCHANT_ID=...
# PAYTR_API_KEY=...

# ============ SMS/EMAIL (ilerde) ============
# NETGSM_USERNAME=...
# NETGSM_PASSWORD=...
# SENDGRID_API_KEY=...

# ============ STORAGE (ilerde) ============
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_S3_BUCKET=...

# ============ WEB PUSH (VAPID) ============
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_EMAIL=mailto:admin@motorya.com.tr

# ============ NATIVE PUSH (FCM — mobil app) ============
# Firebase Console > Project Settings > Service Accounts > Generate new private key
# JSON dosyasının ham içeriği ya da base64'ü buraya yazılabilir (FcmService ikisini de destekler)
# FIREBASE_SERVICE_ACCOUNT_JSON=...
